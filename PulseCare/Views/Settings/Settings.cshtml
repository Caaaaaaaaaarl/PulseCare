@model PulseCare.Models.User
@{
    ViewData["Title"] = "Portal Settings";
}

<div id="pcToastContainer" class="pc-toast-container"></div>

<div class="pc-page-header mb-4">
    <h3 class="fw-bold mb-1" style="color:var(--pc-text); letter-spacing:-0.3px;">System Configuration Settings</h3>
    <p class="small mb-0" style="color:var(--pc-text-muted);">Manage your personal identity profile parameters and account security preferences</p>
</div>

<div class="row g-4 mb-5">

    <div class="col-md-6">
        <div class="card h-100 border border-light shadow-sm bg-white" style="border-radius: 8px;">
            <div class="card-header border-0 py-3 px-4 bg-white border-bottom">
                <h5 class="fw-bold mb-0 text-dark" style="font-size:1rem; letter-spacing:-0.2px;">👤 Account Profile Information</h5>
            </div>
            <div class="card-body p-4">
                <form id="profileForm" method="post" action="/Settings/UpdateProfile">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary small mb-1">Your Display Full Name</label>
                        <input type="text" id="inputFullName" name="fullName" class="form-control" value="@Model.FullName" required placeholder="Enter full name" style="border-color: #cbd5e1; border-radius: 6px;" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-secondary small mb-1">Registered Access Email</label>
                        <input type="email" id="inputEmail" name="email" class="form-control" value="@Model.Email" required placeholder="username@example.com" style="border-color: #cbd5e1; border-radius: 6px;" />
                    </div>
                    <button type="button" class="btn btn-primary btn-sm px-4 py-2 fw-medium" data-bs-toggle="modal" data-bs-target="#profileConfirmModal" style="background-color: #0284c7; border-color: #0284c7; border-radius: 4px;">
                        Save Profile Settings
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 border border-light shadow-sm bg-white" style="border-radius: 8px;">
            <div class="card-header border-0 py-3 px-4 bg-white border-bottom">
                <h5 class="fw-bold mb-0 text-dark" style="font-size:1rem; letter-spacing:-0.2px;">🔑 Authentication & Security</h5>
            </div>
            <div class="card-body p-4">
                <form id="securityForm" method="post" action="/Settings/UpdateSecurity">

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary small mb-1">Current Secure Password</label>
                        <div class="input-group">
                            <input type="password" id="inputCurrentPassword" name="currentPassword" class="form-control pc-password-input" required placeholder="••••••••" style="border-color: #cbd5e1; border-radius: 6px 0 0 6px; border-right: none;" />
                            <span class="input-group-text pc-password-toggle-btn text-muted" style="background: #ffffff; border-color: #cbd5e1; border-left: none; cursor: pointer; padding-right: 14px; padding-left: 10px; display: flex; align-items: center; justify-content: center; border-radius: 0 6px 6px 0;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-secondary small mb-1">New Secure Password</label>
                        <div class="input-group">
                            <input type="password" id="inputNewPassword" name="newPassword" class="form-control pc-password-input" required placeholder="Enter new password token" style="border-color: #cbd5e1; border-radius: 6px 0 0 6px; border-right: none;" />
                            <span class="input-group-text pc-password-toggle-btn text-muted" style="background: #ffffff; border-color: #cbd5e1; border-left: none; cursor: pointer; padding-right: 14px; padding-left: 10px; display: flex; align-items: center; justify-content: center; border-radius: 0 6px 6px 0;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <button type="button" class="btn btn-dark btn-sm px-4 py-2 fw-medium" data-bs-toggle="modal" data-bs-target="#securityConfirmModal" style="background:#0f172a; border:none; border-radius: 4px;">
                        Rotate Access Keys
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>

<div class="text-muted text-start mt-4" style="font-size:0.75rem; letter-spacing:0.02em; opacity: 0.7;">
    PLATFORM CONFIGURATION NODE REFERENCE ID: <span class="font-monospace fw-bold text-primary">#PC-SET-2026</span>
</div>


<div class="modal fade" id="profileConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 380px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
            <div class="modal-body p-4 text-center">
                <div class="mb-3" style="color: #0284c7;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <h5 class="fw-bold text-dark mb-1">Confirm Profile Update</h5>
                <p class="small text-muted mb-4">Are you sure you want to alter your registered name and contact routing information metrics?</p>
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-light border small px-3.5" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="submitProfileBtn" class="btn btn-primary small px-4 fw-semibold text-white" style="background-color: #0284c7; border-color: #0284c7;">Confirm Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="securityConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 380px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
            <div class="modal-body p-4 text-center">
                <div class="mb-3" style="color: #0f172a;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h5 class="fw-bold text-dark mb-1">Confirm Token Rotation</h5>
                <p class="small text-muted mb-4">Are you sure you want to terminate your active password signature string and assign a new authentication key token?</p>
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-light border small px-3.5" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="submitSecurityBtn" class="btn btn-danger small px-4 fw-semibold text-white" style="background-color: #0f172a; border-color: #0f172a;">Rotate Keys</button>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {

            const eyeOpenIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`;
            const eyeSlashIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>`;

            $('.pc-password-toggle-btn').on('click', function () {
                var toggleBtn = $(this);
                var input = toggleBtn.siblings('.pc-password-input');

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    toggleBtn.html(eyeSlashIcon).addClass('text-primary').removeClass('text-muted');
                } else {
                    input.attr('type', 'password');
                    toggleBtn.html(eyeOpenIcon).addClass('text-muted').removeClass('text-primary');
                }
            });

            function presentToastNotification(isSuccess, title, message) {
                var badgeColor = isSuccess ? '#10b981' : '#ef4444';
                var iconMark = isSuccess ? '✔️' : '⚠️';

                var toastElement = $(`
                    <div class="pc-custom-toast shadow" style="background:#ffffff; border:1px solid #cbd5e1; border-left:4px solid ${badgeColor} !important; border-radius:6px; padding:14px 18px; min-width:320px; display:flex; align-items:center; gap:12px; margin-bottom:10px; opacity:0; transform:translateX(40px); transition:all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
                        <div style="font-size:1.25rem;">${iconMark}</div>
                        <div style="flex-grow:1;">
                            <strong style="color:#0f172a; font-size:0.875rem; display:block; margin-bottom:1px;">${title}</strong>
                            <span style="color:#64748b; font-size:0.8rem; display:block; line-height:1.3;">${message}</span>
                        </div>
                    </div>
                `);

                $('#pcToastContainer').append(toastElement);

                setTimeout(function () {
                    toastElement.css({ 'opacity': '1', 'transform': 'translateX(0)' });
                }, 50);

                setTimeout(function () {
                    toastElement.css({ 'opacity': '0', 'transform': 'translateY(-10px)' });
                    setTimeout(function () {
                        toastElement.remove();
                    }, 300);
                }, 3500);
            }

            $('#submitProfileBtn').on('click', function () {
                $('#profileConfirmModal').modal('hide');

                $.ajax({
                    url: '/Settings/UpdateProfile',
                    type: 'POST',
                    data: {
                        fullName: $('#inputFullName').val(),
                        email: $('#inputEmail').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            presentToastNotification(true, "Profile Updated", res.message);
                            $('.pc-sidebar-user .fw-semibold').text(res.updatedName);
                        } else {
                            presentToastNotification(false, "Update Failed", res.message);
                        }
                    },
                    error: function () {
                        presentToastNotification(false, "Link Failure", "Could not synchronize dashboard context updates.");
                    }
                });
            });

            $('#submitSecurityBtn').on('click', function () {
                $('#securityConfirmModal').modal('hide');

                var currentPass = $('#inputCurrentPassword').val();
                var newPass = $('#inputNewPassword').val();

                if (!currentPass || !newPass) {
                    presentToastNotification(false, "Validation Fault", "Please populate both password inputs.");
                    return;
                }

                $.ajax({
                    url: '/Settings/UpdateSecurity',
                    type: 'POST',
                    data: {
                        currentPassword: currentPass,
                        newPassword: newPass
                    },
                    success: function (res) {
                        if (res.success) {
                            presentToastNotification(true, "Password Swapped", res.message);
                            $('#inputCurrentPassword').val('');
                            $('#inputNewPassword').val('');
                        } else {
                            presentToastNotification(false, "Authentication Mismatch", res.message);
                        }
                    },
                    error: function () {
                        presentToastNotification(false, "Security Link Fault", "Failed to commit credential string rotations.");
                    }
                });
            });

        });
    </script>
}

<style>
    .pc-toast-container {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 10000;
        display: flex;
        flex-direction: column-reverse;
        pointer-events: none;
    }

    .pc-custom-toast {
        pointer-events: auto;
    }
</style>