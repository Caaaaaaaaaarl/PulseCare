@{
    ViewData["Title"] = "Current Patients";
}

<div class="pc-page-header mb-4">
    <h3 class="fw-bold mb-1" style="color: var(--pc-text); letter-spacing: -0.5px;">Active Patient Records Directory</h3>
    <p class="small mb-0" style="color: var(--pc-text-muted);">Real-time monitoring panel displaying clinical directory parameters for active caseloads</p>
</div>

<div class="card border-0 shadow-sm overflow-hidden bg-white mb-5" style="border-radius: 8px;">
    <div class="table-responsive">
        <table class="table align-middle pc-table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Patient Profile Name</th>
                    <th>Secure Routing Email</th>
                    <th>Next Scheduled Intake</th>
                    <th>Primary Case Symptoms</th>
                    <th class="text-end pe-4">Administrative Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.ActivePatients == null || ViewBag.ActivePatients.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted small">
                            <span class="fs-4 d-block mb-2">👥</span>
                            No active or pending patient monitoring nodes assigned to your clinical queue directory.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var patient in ViewBag.ActivePatients)
                    {
                        <tr class="border-bottom">
                            <td class="ps-4 fw-semibold text-dark">@patient.PatientName</td>
                            <td class="text-secondary small">@patient.PatientEmail</td>
                            <td class="font-monospace text-primary fw-medium" style="font-size: 0.85rem;">
                                @patient.NextConsultationDate.ToString("MM/dd/yyyy hh:mm tt")
                            </td>
                            <td class="text-muted small text-truncate" style="max-width: 320px;" title="@patient.CaseIssue">
                                @patient.CaseIssue
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" 
                                        class="btn btn-sm btn-light border fw-semibold px-3 py-1.5 open-current-summary-btn" 
                                        data-id="@patient.Id"
                                        style="font-size: 0.8rem; border-radius: 4px; color: #334155;">
                                    View Details
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="text-muted text-start mt-4" style="font-size: 0.75rem; letter-spacing: 0.02em; opacity: 0.7;">
    ACTIVE DIRECTORY VALIDATION ENCRYPTED NODE MAP: <span class="font-monospace fw-bold text-success">#PC-DOC-ACTIVE-DIR</span>
</div>


<div class="modal fade" id="currentSummaryCardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 460px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
            
            <div class="py-3.5 px-4 text-white d-flex align-items-center justify-content-between" style="background: #0f172a;">
                <div class="d-flex align-items-center gap-2">
                    <span class="fs-5">📋</span>
                    <h5 class="modal-title fw-bold mb-0" style="font-size: 0.95rem; letter-spacing: -0.1px;">Active Consultation Summary</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="font-size: 0.75rem;"></button>
            </div>

            <div class="modal-body p-4 bg-light" style="max-height: 80vh; overflow-y: auto;">
                
                <div class="mb-3 text-end">
                    <span id="cardDateStamp" class="font-monospace text-uppercase small px-2.5 py-1 rounded bg-secondary bg-opacity-10 text-secondary fw-semibold" style="font-size: 0.725rem;">MM/DD/YYYY</span>
                </div>

                <div class="card border border-light shadow-sm mb-3 bg-white" style="border-radius: 6px;">
                    <div class="card-body p-3">
                        <label class="text-uppercase font-monospace text-muted gold-title-badge fw-bold d-block mb-1" style="font-size: 0.675rem; letter-spacing: 0.04em;">Reported Case Symptoms</label>
                        <p id="cardSymptomsText" class="text-dark fw-semibold mb-0" style="font-size: 0.875rem; line-height: 1.4;"></p>
                    </div>
                </div>

                <div class="card border border-light shadow-sm mb-3 bg-white" style="border-radius: 6px; border-left: 3.5px solid #0284c7 !important;">
                    <div class="card-body p-3">
                        <label class="text-uppercase font-monospace text-info fw-bold d-block mb-1" style="font-size: 0.675rem; letter-spacing: 0.04em;">Attending Physician Diagnosis Notes</label>
                        <p id="cardNotesText" class="text-secondary mb-0" style="font-size: 0.85rem; line-height: 1.45; white-space: pre-line;"></p>
                    </div>
                </div>

                <div class="card border border-light shadow-sm bg-white" style="border-radius: 6px; border-left: 3.5px solid #10b981 !important;">
                    <div class="card-body p-3">
                        <label class="text-uppercase font-monospace text-success fw-bold d-block mb-1" style="font-size: 0.675rem; letter-spacing: 0.04em;">Diet Plan & Prescriptions</label>
                        <p id="cardRxText" class="text-secondary mb-0" style="font-size: 0.85rem; line-height: 1.45; white-space: pre-line;"></p>
                    </div>
                </div>

            </div>

            <div class="modal-footer border-0 p-3 bg-white d-flex justify-content-end border-top">
                <button type="button" class="btn btn-dark btn-sm px-4 fw-medium" data-bs-dismiss="modal" style="font-size: 0.825rem; border-radius: 4px;">Dismiss Chart</button>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            
            // Asynchronous AJAX Pipeline Engine Trigger Interceptor
            $('.open-current-summary-btn').on('click', function () {
                var btn = $(this);
                var appointmentId = btn.data('id');

                btn.prop('disabled', true).text('Loading... ⏳');

                $.ajax({
                    url: '/Consultation/GetConsultationDetails',
                    type: 'GET',
                    data: { id: appointmentId },
                    success: function (res) {
                        if (res.success) {
                            // Map JSON properties to modal elements cleanly
                            $('#cardDateStamp').text(res.date);
                            $('#cardSymptomsText').text(res.symptoms);
                            $('#cardNotesText').text(res.notes);
                            $('#cardRxText').text(res.rx);

                            // Open the summary dialog container box
                            $('#currentSummaryCardModal').modal('show');
                        } else {
                            alert('Query execution mismatch: ' + res.message);
                        }
                    },
                    error: function () {
                        alert('System link fault: Failed to sync current data nodes.');
                    },
                    complete: function () {
                        btn.prop('disabled', false).text('View Details');
                    }
                });
            });

        });
    </script>
}