@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center py-5">
        <div class="col-lg-8">
            <div class="d-inline-flex align-items-center justify-content-center px-3 py-1 fw-medium small mb-4 rounded-pill" style="background-color: var(--pc-primary-subtle); color: var(--pc-primary);">
                🚀 Running on .NET 10 Web Engine
            </div>
            <h1 class="display-4 fw-bold mb-3" style="color: var(--pc-text); letter-spacing: -1px;">Welcome to PulseCare</h1>
            <p class="lead px-md-5 mb-5" style="color: var(--pc-text-muted);">A streamlined, real-time clinical solution optimized for immediate e-medicine and chronic lifestyle metrics synchronization.</p>

            <div class="p-4 border text-start mx-auto rounded-3" style="background-color: var(--pc-surface); border-color: var(--pc-border) !important; max-width: 500px; box-shadow: var(--pc-shadow-card);">
                <p class="mb-2 fw-medium" style="color: var(--pc-text);">Core Technical Reference Documentation:</p>
                <span class="small d-block mb-0" style="color: var(--pc-text-muted);">Learn about <a class="fw-medium text-decoration-none" style="color: var(--pc-primary);" href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core Framework</a>.</span>
            </div>
        </div>
    </div>
</div>
