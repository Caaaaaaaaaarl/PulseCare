@{
    ViewData["Title"] = "My Appointments";
}

<div class="pc-page-header mb-4">
    <h3 class="fw-bold mb-1" style="color:var(--pc-text); letter-spacing:-0.5px;">My Booked Appointments</h3>
    <p class="small mb-0" style="color:var(--pc-text-muted);">Track your clinical check-in status, triage priority levels, and upcoming consultations</p>
</div>

<div class="card border-0 shadow-sm overflow-hidden bg-white mb-5">
    <div class="table-responsive">
        <table class="table align-middle pc-table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Assigned Medical Specialist</th>
                    <th>Scheduled Date & Time</th>
                    <th>Reported Case Symptoms</th>
                    <th class="text-end pe-4">Status Clearance</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Appointments.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted small">
                            <span class="fs-4 d-block mb-2">📅</span>
                            You have no booked appointments recorded in your health history profile ledger.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var app in ViewBag.Appointments)
                    {
                        <tr class="border-bottom">
                            <td class="ps-4 fw-semibold text-dark">@app.DoctorName</td>
                            <td class="font-monospace text-secondary" style="font-size: 0.85rem;">
                                @app.AppointmentDate.ToString("MM/dd/yyyy hh:mm tt")
                            </td>
                            <td class="text-truncate text-muted small" style="max-width: 320px;" title="@app.Symptoms">
                                @app.Symptoms
                            </td>
                            <td class="text-end pe-4">
                                @if (app.Status == "Completed")
                                {
                                    <span class="pc-badge pc-badge-success">Session Concluded</span>
                                }
                                else if (app.Status == "Pending")
                                {
                                    <span class="pc-badge pc-badge-neutral">Awaiting Practitioner</span>
                                }
                                else
                                {
                                    <span class="pc-badge pc-badge-primary">@app.Status</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="text-muted text-start mt-4" style="font-size:0.75rem; letter-spacing:0.02em; opacity: 0.7;">
    LEDGER ACCESS DOMAIN NODE REFERENCE: <span class="font-monospace fw-bold text-primary">#PC-APP-TRACK</span>
</div>