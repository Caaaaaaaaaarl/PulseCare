@{
    ViewData["Title"] = "Patient Queue";
}

<div class="pc-page-header mb-4">
    <h3 class="fw-bold mb-1" style="color: var(--pc-text); letter-spacing: -0.5px;">Pending Virtual Consultations</h3>
    <p class="small mb-0" style="color: var(--pc-text-muted);">Real-time patient triage matrix synchronization stream</p>
</div>

@if (ViewBag.AssignedQueue == null || ViewBag.AssignedQueue.Count == 0)
{
    <div class="card border-0 shadow-sm bg-white mb-4 text-center py-5" style="border-radius: 8px;">
        <div class="card-body py-5">
            <div class="fs-1 mb-3">🎉</div>
            <h5 class="fw-medium text-dark mb-4" style="font-size: 1.1rem;">You have no pending patients in your queue.</h5>
            <a href="/Home/DoctorDashboard" class="btn btn-light border btn-sm px-4 py-2 text-secondary" style="font-size: 0.85rem; border-radius: 4px;">
                ← Back to Dashboard
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm overflow-hidden bg-white mb-5" style="border-radius: 8px;">
        <div class="table-responsive">
            <table class="table align-middle pc-table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Patient Full Name</th>
                        <th>Scheduled Date & Time</th>
                        <th>Reported Case Symptoms</th>
                        <th class="text-end pe-4">Administrative Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.AssignedQueue)
                    {
                        <tr class="border-bottom">
                            <td class="ps-4 fw-semibold text-dark">@item.PatientName</td>
                            <td class="font-monospace text-secondary" style="font-size: 0.85rem;">
                                @item.AppointmentDate.ToString("MM/dd/yyyy hh:mm tt")
                            </td>
                            <td class="text-muted small text-truncate" style="max-width: 380px;" title="@item.Symptoms">
                                @item.Symptoms
                            </td>
                            <td class="text-end pe-4">
                                <a href="/Consultation/Checkout/@item.Id" class="btn btn-primary btn-sm fw-medium px-3 py-1.5" style="background-color: #0284c7; border-color: #0284c7; font-size: 0.85rem; border-radius: 4px;">
                                    Start Consultation
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="text-muted text-start mt-4" style="font-size: 0.75rem; letter-spacing: 0.02em; opacity: 0.7;">
    CLINICAL INTAKE FLOW MATRIX COMPONENT MAP: <span class="font-monospace fw-bold text-primary">#PC-DOC-QUEUE</span>
</div>