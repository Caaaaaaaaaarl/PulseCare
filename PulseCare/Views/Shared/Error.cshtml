@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center text-center py-4">
    <div class="col-md-8 col-lg-6">

        <div class="mb-3">
            <span class="display-3" style="opacity:0.45;">⚠️</span>
        </div>

        <h2 class="fw-bold mb-1" style="color:var(--pc-text);letter-spacing:-0.5px;">Execution Error</h2>
        <p class="small mb-4" style="color:var(--pc-text-muted);">An error occurred while processing your request within this clinical terminal block.</p>

        @if (Model.ShowRequestId)
        {
            <div class="d-inline-block px-4 py-2 mb-4"
                 style="background:var(--pc-surface);border:1px solid var(--pc-border);border-radius:var(--pc-radius-sm);box-shadow:var(--pc-shadow-card);">
                <span class="small me-2" style="color:var(--pc-text-muted);">Request ID Token:</span>
                <code class="fw-bold font-monospace" style="color:var(--pc-danger);">@Model.RequestId</code>
            </div>
        }

        <div class="card text-start overflow-hidden mt-2">
            <div class="card-header pc-card-header-dark py-3 px-4">
                <h6 class="fw-bold mb-0 small font-monospace text-white">💻 DEVELOPER DIAGNOSTICS NODE LOG</h6>
            </div>
            <div class="card-body p-4" style="font-size:0.8125rem;line-height:1.6;color:var(--pc-text-muted);">
                <p class="mb-3 font-monospace">Swapping to <strong style="color:var(--pc-text);">Development</strong> environment will display more detailed information about the exception.</p>
                <div class="p-3 mb-3 small" style="background:var(--pc-danger-subtle);border:1px solid #fca5a5;border-radius:var(--pc-radius-sm);color:var(--pc-text);">
                    <strong>Environment Warning:</strong> The Development environment shouldn't be enabled for deployed production nodes as it can leak exception metadata schema traces.
                </div>
                <p class="mb-0 font-monospace" style="opacity:0.7;">Enable by setting <code>ASPNETCORE_ENVIRONMENT</code> environment variable to <code>Development</code> and rebooting the host instance.</p>
            </div>
        </div>

    </div>
</div>
