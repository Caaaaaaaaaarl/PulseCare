@{
    ViewData["Title"] = "Patient History";
}

<div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
    <div>
        <h3 class="fw-bold mb-1" style="color: var(--pc-text); letter-spacing: -0.5px;">Patient Medical Consultation History</h3>
        <p class="small mb-0" style="color: var(--pc-text-muted);">Historical logs archive tracking all completed consultation charts and diagnostic logs</p>
    </div>
    
    <div class="input-group" style="max-width: 320px;">
        <span class="input-group-text bg-white border-end-0 text-muted small" style="border-color: #cbd5e1; border-radius: 6px 0 0 6px;">🔍</span>
        <input type="text" id="historyFilterInput" class="form-control font-monospace small" placeholder="Filter by patient name..." 
               style="border-color: #cbd5e1; border-radius: 0 6px 6px 0; font-size: 0.85rem; height: 38px;" />
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden bg-white mb-5" style="border-radius: 8px;">
    <div class="table-responsive">
        <table class="table align-middle pc-table mb-0" id="historyTableRecords">
            <thead>
                <tr>
                    <th class="ps-4">Patient Full Name</th>
                    <th>Date Concluded</th>
                    <th>Reported Symptoms Summary</th>
                    <th class="text-end pe-4">Administrative Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.PastConsultations == null || ViewBag.PastConsultations.Count == 0)
                {
                    <tr id="emptyPlaceholderRow">
                        <td colspan="4" class="text-center py-5 text-muted small">
                            <span class="fs-4 d-block mb-2">📜</span>
                            No historically concluded consultations or signed medical charts found in your archive logs.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var caseLog in ViewBag.PastConsultations)
                    {
                        <tr class="border-bottom target-history-row">
                            <td class="ps-4 fw-semibold text-dark patient-target-cell">@caseLog.PatientName</td>
                            <td class="font-monospace text-secondary" style="font-size: 0.85rem;">
                                @caseLog.ConcludedDate.ToString("MM/dd/yyyy hh:mm tt")
                            </td>
                            <td class="text-muted small text-truncate" style="max-width: 340px;" title="@caseLog.SymptomsReported">
                                @caseLog.SymptomsReported
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" 
                                        class="btn btn-sm btn-light border fw-semibold px-3 py-1.5 open-summary-card-btn" 
                                        data-id="@caseLog.Id"
                                        style="font-size: 0.8rem; border-radius: 4px; color: #334155;">
                                    View Details
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="text-muted text-start mt-4" style="font-size: 0.75rem; letter-spacing: 0.02em; opacity: 0.7;">
    CLINICAL LEDGER ENCRYPTED HISTORICAL MAP: <span class="font-monospace fw-bold text-primary">#PC-DOC-ARCHIVE</span>
</div>


<div class="modal fade" id="clinicalSummaryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 460px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
            
            <div class="py-3.5 px-4 text-white d-flex align-items-center justify-content-between" style="background: #0f172a;">
                <div class="d-flex align-items-center gap-2">
                    <span class="fs-5">📋</span>
                    <h5 class="modal-title fw-bold mb-0" style="font-size: 0.95rem; letter-spacing: -0.1px;">Concluded Consultation Summary</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="font-size: 0.75rem;"></button>
            </div>

            <div class="modal-body p-4 bg-light" style="max-height: 80vh; overflow-y: auto;">
                
                <div class="mb-3 text-end">
                    <span id="modalDateStamp" class="font-monospace text-uppercase small px-2.5 py-1 rounded bg-secondary bg-opacity-10 text-secondary fw-semibold" style="font-size: 0.725rem;">MM/DD/YYYY</span>
                </div>

                <div class="card border border-light shadow-sm mb-3 bg-white" style="border-radius: 6px;">
                    <div class="card-body p-3">
                        <label class="text-uppercase font-monospace text-muted fw-bold d-block mb-1" style="font-size: 0.675rem; letter-spacing: 0.04em;">Reported Patient Symptoms</label>
                        <p id="modalSymptomsText" class="text-dark fw-semibold mb-0" style="font-size: 0.875rem; line-height: 1.4;"></p>
                    </div>
                </div>

                <div class="card border border-light shadow-sm mb-3 bg-white" style="border-radius: 6px; border-left: 3.5px solid #0284c7 !important;">
                    <div class="card-body p-3">
                        <label class="text-uppercase font-monospace text-info fw-bold d-block mb-1" style="font-size: 0.675rem; letter-spacing: 0.04em;">Attending Physician Diagnosis Notes</label>
                        <p id="modalNotesText" class="text-secondary mb-0" style="font-size: 0.85rem; line-height: 1.45; white-space: pre-line;"></p>
                    </div>
                </div>

                <div class="card border border-light shadow-sm bg-white" style="border-radius: 6px; border-left: 3.5px solid #10b981 !important;">
                    <div class="card-body p-3">
                        <label class="text-uppercase font-monospace text-success fw-bold d-block mb-1" style="font-size: 0.675rem; letter-spacing: 0.04em;">Diet Plan & Prescriptions</label>
                        <p id="modalRxText" class="text-secondary mb-0" style="font-size: 0.85rem; line-height: 1.45; white-space: pre-line;"></p>
                    </div>
                </div>

            </div>

            <div class="modal-footer border-0 p-3 bg-white d-flex justify-content-end border-top">
                <button type="button" class="btn btn-dark btn-sm px-4 fw-medium" data-bs-dismiss="modal" style="font-size: 0.825rem; border-radius: 4px;">Dismiss Chart</button>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            
            // 🔍 OPTION B IMPLEMENTATION: Client-Side Fast Filtering Keypress Interceptor Engine
            $('#historyFilterInput').on('keyup', function () {
                var searchToken = $(this).val().toLowerCase().trim();
                var matchingRowCount = 0;

                $('.target-history-row').each(function () {
                    var currentRow = $(this);
                    var patientName = currentRow.find('.patient-target-cell').text().toLowerCase();

                    if (patientName.indexOf(searchToken) > -1) {
                        currentRow.show();
                        matchingRowCount++;
                    } else {
                        currentRow.hide();
                    }
                });

                // Toggle empty info panel rows dynamically if everything is filtered out
                if (matchingRowCount === 0 && $('.target-history-row').length > 0) {
                    if ($('#filterPlaceholderRow').length === 0) {
                        $('#historyTableRecords tbody').append(`
                            <tr id="filterPlaceholderRow">
                                <td colspan="4" class="text-center py-5 text-muted small">
                                    No archive patient profiles match the keyword phrase "${$(this).val()}".
                                </td>
                            </tr>
                        `);
                    }
                } else {
                    $('#filterPlaceholderRow').remove();
                }
            });

            // 📋 OPTION A & STEP 2 IMPLEMENTATION: Background AJAX Pipeline Trigger Interceptor
            $('.open-summary-card-btn').on('click', function () {
                var triggerButton = $(this);
                var consultationId = triggerButton.data('id');

                // Toggle loading text state parameter variables
                triggerButton.prop('disabled', true).text('Loading... ⏳');

                $.ajax({
                    url: '/Consultation/GetConsultationDetails',
                    type: 'GET',
                    data: { id: consultationId },
                    success: function (res) {
                        if (res.success) {
                            // Map JSON properties to modal elements
                            $('#modalDateStamp').text(res.date);
                            $('#modalSymptomsText').text(res.symptoms);
                            $('#modalNotesText').text(res.notes);
                            $('#modalRxText').text(res.rx);

                            // Trigger modal show frame
                            $('#clinicalSummaryModal').modal('show');
                        } else {
                            alert('Failed to parse logs: ' + res.message);
                        }
                    },
                    error: function () {
                        alert('System link fault: Failed to pull archival details data node.');
                    },
                    complete: function () {
                        // Restore button processing text parameters cleanly
                        triggerButton.prop('disabled', false).text('View Details');
                    }
                });
            });

        });
    </script>
}