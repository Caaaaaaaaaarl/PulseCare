@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow border-info">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Schedule Virtual Consultation</h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="Book" asp-controller="Appointment">

                        <div class="mb-3">
                            <label class="fw-bold">Select Physician</label>
                            <select name="doctorId" class="form-select" required>
                                <option value="">-- Choose a Doctor --</option>
                                @foreach (var doctor in ViewBag.Doctors)
                                {
                                    <option value="@doctor.Id">@doctor.FullName</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Preferred Date & Time</label>
                            <input type="datetime-local" name="appointmentDate" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Describe your symptoms</label>
                            <small class="d-block text-muted mb-2">Our Smart Triage system will analyze your symptoms to prioritize your care.</small>
                            <textarea name="symptoms" class="form-control" rows="4" placeholder="e.g., I have had a high fever and severe headache for 2 days..." required></textarea>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Home/PatientDashboard" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-info text-white fw-bold">Submit Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>